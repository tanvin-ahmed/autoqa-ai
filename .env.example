# App Setup
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Neon Serverless Postgres Database (Drizzle ORM)
DATABASE_URL=postgresql://neondb_owner:your_password@ep-placeholder-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

# Clerk Authentication — paste real keys from https://dashboard.clerk.com (API Keys).
# Placeholder strings like pk_test_placeholder are invalid and will crash Clerk.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Stripe — minimal: secret + webhook signing + recurring Pro Price id (`price_*` from Dashboard).
# The $30/mo charge is configured on that Price in Stripe (amount + currency + interval), not in this repo.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
# Optional defaults: CREDITS_SUBSCRIPTION_MONTHLY=10000
# Optional top-up Checkout: STRIPE_PRICE_CREDITS_TOPUP=price_…  CREDITS_TOPUP_AMOUNT=5000

# GitHub OAuth (must match GitHub App callback URL exactly, e.g. http://localhost:3000/api/github/callback)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/api/github/callback

# Google Gemini (`/api/generate-test-cases`, `/api/test-cases/run` regeneration)
GEMINI_API_KEY=
# Optional — retries on 429/503, then fallback model when primary is overloaded
GEMINI_SCRIPT_MODEL=gemini-2.5-flash
GEMINI_SCRIPT_MODEL_FALLBACK=gemini-2.0-flash
GEMINI_RETRY_ATTEMPTS=3
# Model used for suite generation (`POST /api/generate-test-cases`)
GEMINI_SUITE_MODEL=gemini-2.5-flash
# Conservative max output tokens assumed for pre-flight credit checks before calling Gemini (not a hard SDK cap).
GEMINI_SUITE_MAX_OUTPUT_TOKENS_ESTIMATE=8192
GEMINI_SCRIPT_MAX_OUTPUT_TOKENS_ESTIMATE=8192

# Credit metering (`users.credits`) — proportional to Gemini `usageMetadata` token counts reported by `@google/genai`.
# Charges use: ceil(prompt/1e6 * PROMPT_RATE + completion/1e6 * RESPONSE_RATE), clamped between MIN and MAX per call.
# If the SDK omits counts, chars/4 heuristics approximate tokens from the rendered prompt/output text.
CREDITS_PER_MILLION_PROMPT_TOKENS=5000
CREDITS_PER_MILLION_RESPONSE_TOKENS=15000
CREDITS_GEMINI_MIN_PER_CALL=2
CREDITS_GEMINI_MAX_PER_CALL=2500

# Browserless (`/api/test-cases/run`) — bill elapsed wall seconds from successful CDP connect until disconnect closes.
# Formula: max(MIN_CREDITS, ceil(BASE + seconds * PER_SECOND)); optional CAP per session when > 0.
CREDITS_BROWSERLESS_BASE=8
CREDITS_BROWSERLESS_PER_SECOND=0.15
CREDITS_BROWSERLESS_MIN=10
CREDITS_BROWSERLESS_MAX_PER_SESSION=0
CREDITS_BROWSERLESS_MIN_BILL_SECONDS=1

# Browserless — hosted CDP for `/api/test-cases/run` (Playwright `chromium.connectOverCDP`).
BROWSERLESS_WS_ENDPOINT=wss://production-sfo.browserless.io
BROWSERLESS_TOKEN=
# Optional — HTTPS surface for “Open dashboard link” in the test runner (`session_url`).
BROWSERLESS_DASHBOARD_URL=

# ── Deploying on Vercel (Hobby etc.)
# Duplicate every secret above into Project → Settings → Environment Variables for Production (+ Preview if needed).
# `POST /api/test-cases/run` needs long CPU time — the route sets `maxDuration = 60` (Hobby cap). On Pro you can raise that export toward 300 in `app/api/test-cases/run/route.ts`.
# Sync Neon columns/tables with `db/schema.ts` (e.g. run `db/migrations/001_stripe_billing.sql` in Neon SQL or `pnpm drizzle-kit push`).
# GitHub OAuth: add your prod domain + redirect URL (`GITHUB_REDIRECT_URI`, `NEXT_PUBLIC_APP_URL`). Clerk needs prod URLs allowed too.
